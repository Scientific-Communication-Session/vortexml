# Copy this file to `.env` (already git-ignored) and fill in real values.
# `start.sh` sources `.env` before launching, so anything you set here ends up
# in the backend's environment.

# Required to enable the Novice-mode chatbot. Without it, /api/chat returns 503
# and the frontend hides the chat UI for novices.
ANTHROPIC_API_KEY=

# Optional. Force the backend onto SQLite even when PostgreSQL is reachable.
# Set to 1 to skip the Postgres probe in start.sh.
# VORTEX_USE_SQLITE=1

# Public URL of this server, baked into downloaded node-agent bundles so a
# user's own machine knows where to dial back in. Defaults to the production
# tunnel. Override it for local testing, e.g. http://192.168.100.95:5173
# VORTEX_PUBLIC_URL=https://vortexml.andreinita.com
